#!/usr/bin/env bash
# auto - friendly power profile daemon
# Monitors heat + load and suggests profile changes without stealing focus.
# Version: 1.3.0

set -u

CONF_FILE="/etc/boost-auto.conf"
STATE_DIR="/var/lib/power-profile"

SERVICE="boost-auto.service"
WEB_SERVICE="boost-web.service"
WEB_URL="http://127.0.0.1:8765"
SNOOZE_FILE="$STATE_DIR/auto-snooze-until"
SKIP_TODAY_FILE="$STATE_DIR/auto-skip-date"
REPORT_BIN="/usr/local/bin/power-report"


# Friendly defaults. Use `auto mode dynamic|creator|quiet|off`.
AUTO_MODE="${AUTO_MODE:-dynamic}"
QUIET_HOURS_START="${QUIET_HOURS_START:-22:00}"
QUIET_HOURS_END="${QUIET_HOURS_END:-08:00}"
ALLOW_CRITICAL_AUTO="${ALLOW_CRITICAL_AUTO:-yes}"
SUMMER_SILENT_NIGHTS="${SUMMER_SILENT_NIGHTS:-no}"
AMBIENT_TEMP_C="${AMBIENT_TEMP_C:-}"
AMBIENT_TEMP_FILE="${AMBIENT_TEMP_FILE:-}"
TEMP_CRITICAL="${TEMP_CRITICAL:-85}"
TEMP_HOT="${TEMP_HOT:-78}"
BOOST_TEMP_LIMIT="${BOOST_TEMP_LIMIT:-78}"
LOAD_HIGH="${LOAD_HIGH:-75}"
LOAD_HIGH_DURATION="${LOAD_HIGH_DURATION:-120}"
LOAD_IDLE="${LOAD_IDLE:-8}"
LOAD_IDLE_DURATION="${LOAD_IDLE_DURATION:-600}"
PROMPT_COOLDOWN="${PROMPT_COOLDOWN:-900}"
POLL_INTERVAL="${POLL_INTERVAL:-5}"
STATS_INTERVAL="${STATS_INTERVAL:-60}"

reset_threshold_defaults() {
    TEMP_CRITICAL=85
    TEMP_HOT=78
    BOOST_TEMP_LIMIT=78
    LOAD_HIGH=75
    LOAD_HIGH_DURATION=120
    LOAD_IDLE=8
    LOAD_IDLE_DURATION=600
    PROMPT_COOLDOWN=900
}

if [[ "${BOOST_AUTO_NO_CONFIG:-0}" != "1" && -f "$CONF_FILE" ]]; then
    # shellcheck source=/etc/boost-auto.conf disable=SC1091
    source /etc/boost-auto.conf
fi

CUSTOM_TEMP_CRITICAL="${TEMP_CRITICAL}"
CUSTOM_TEMP_HOT="${TEMP_HOT}"
CUSTOM_BOOST_TEMP_LIMIT="${BOOST_TEMP_LIMIT}"
CUSTOM_LOAD_HIGH="${LOAD_HIGH}"
CUSTOM_LOAD_HIGH_DURATION="${LOAD_HIGH_DURATION}"
CUSTOM_LOAD_IDLE="${LOAD_IDLE}"
CUSTOM_LOAD_IDLE_DURATION="${LOAD_IDLE_DURATION}"
CUSTOM_PROMPT_COOLDOWN="${PROMPT_COOLDOWN}"

if [[ -f /usr/local/lib/power-common.sh ]]; then
    # shellcheck source=/usr/local/lib/power-common.sh disable=SC1091
    source /usr/local/lib/power-common.sh
fi

apply_mode_preset() {
    reset_threshold_defaults
    case "${AUTO_MODE:-dynamic}" in
        dynamic)
            TEMP_HOT=78
            BOOST_TEMP_LIMIT=78
            LOAD_HIGH=75
            LOAD_HIGH_DURATION=120
            LOAD_IDLE=8
            LOAD_IDLE_DURATION=600
            PROMPT_COOLDOWN=900
            ;;
        gaming)
            TEMP_HOT=80
            BOOST_TEMP_LIMIT=80
            LOAD_HIGH=50
            LOAD_HIGH_DURATION=30
            LOAD_IDLE=10
            LOAD_IDLE_DURATION=600
            PROMPT_COOLDOWN=900
            ;;
        creator)
            TEMP_HOT=82
            BOOST_TEMP_LIMIT=82
            LOAD_HIGH=85
            LOAD_HIGH_DURATION=30
            LOAD_IDLE=15
            LOAD_IDLE_DURATION=1200
            PROMPT_COOLDOWN=300
            ;;
        quiet)
            TEMP_HOT=70
            BOOST_TEMP_LIMIT=70
            LOAD_HIGH=90
            LOAD_HIGH_DURATION=600
            LOAD_IDLE=5
            LOAD_IDLE_DURATION=120
            PROMPT_COOLDOWN=3600
            ;;
        off) ;;
        custom)
            [[ -n "${CUSTOM_TEMP_CRITICAL:-}" ]] && TEMP_CRITICAL="$CUSTOM_TEMP_CRITICAL"
            [[ -n "${CUSTOM_TEMP_HOT:-}" ]] && TEMP_HOT="$CUSTOM_TEMP_HOT"
            [[ -n "${CUSTOM_BOOST_TEMP_LIMIT:-}" ]] && BOOST_TEMP_LIMIT="$CUSTOM_BOOST_TEMP_LIMIT"
            [[ -n "${CUSTOM_LOAD_HIGH:-}" ]] && LOAD_HIGH="$CUSTOM_LOAD_HIGH"
            [[ -n "${CUSTOM_LOAD_HIGH_DURATION:-}" ]] && LOAD_HIGH_DURATION="$CUSTOM_LOAD_HIGH_DURATION"
            [[ -n "${CUSTOM_LOAD_IDLE:-}" ]] && LOAD_IDLE="$CUSTOM_LOAD_IDLE"
            [[ -n "${CUSTOM_LOAD_IDLE_DURATION:-}" ]] && LOAD_IDLE_DURATION="$CUSTOM_LOAD_IDLE_DURATION"
            [[ -n "${CUSTOM_PROMPT_COOLDOWN:-}" ]] && PROMPT_COOLDOWN="$CUSTOM_PROMPT_COOLDOWN"
            ;;
        *)
            AUTO_MODE=dynamic
            ;;
    esac
}

ensure_state_dir() {
    mkdir -p "$STATE_DIR"
}

numeric_temp() {
    [[ "${1:-}" =~ ^-?[0-9]+([.][0-9]+)?$ ]]
}

whole_celsius() {
    local value="$1"
    value="${value%%.*}"
    printf '%s\n' "$value"
}

read_ambient_temp_c() {
    local raw hwmon label_file label input_file
    if numeric_temp "${AMBIENT_TEMP_C:-}"; then
        whole_celsius "$AMBIENT_TEMP_C"
        return 0
    fi
    if [[ -n "${AMBIENT_TEMP_FILE:-}" && -r "$AMBIENT_TEMP_FILE" ]]; then
        raw=$(tr -cd '0-9.-' < "$AMBIENT_TEMP_FILE" | head -c 8)
        if numeric_temp "$raw"; then
            if (( ${raw%%.*} > 200 )); then
                echo $(( ${raw%%.*} / 1000 ))
            else
                whole_celsius "$raw"
            fi
            return 0
        fi
    fi
    for hwmon in /sys/class/hwmon/hwmon*; do
        [[ -d "$hwmon" ]] || continue
        for label_file in "$hwmon"/temp*_label; do
            [[ -r "$label_file" ]] || continue
            label=$(tr '[:upper:]' '[:lower:]' < "$label_file")
            case "$label" in
                *ambient*|*room*|*system*|*motherboard*|*systin*)
                    input_file="${label_file%_label}_input"
                    raw=$(cat "$input_file" 2>/dev/null || echo 0)
                    if [[ "$raw" =~ ^[0-9]+$ && "$raw" -gt 0 ]]; then
                        echo $(( raw / 1000 ))
                        return 0
                    fi
                    ;;
            esac
        done
    done
    return 1
}

apply_ambient_adjustment() {
    return 0
}

refresh_mode_settings() {
    local ambient=""
    apply_mode_preset
    ambient=$(read_ambient_temp_c 2>/dev/null || true)
    apply_ambient_adjustment "$ambient"
}

mode_description() {
    case "${1:-dynamic}" in
        dynamic) echo "balanced everyday" ;;
        gaming)  echo "optimized for games" ;;
        creator) echo "gaming/rendering limits" ;;
        quiet)   echo "strictly low noise/heat" ;;
        off)     echo "disabled" ;;
        custom)  echo "advanced config values" ;;
        *)       echo "unknown" ;;
    esac
}

print_mode_row() {
    local mode="$1" old_mode="$AUTO_MODE"
    AUTO_MODE="$mode"
    apply_mode_preset
    printf '%-9s hot=%-3s critical=%-3s boost-below=%-3s busy=%s/%s idle=%s/%s cooldown=%-6s %s\n' \
        "$mode" "$TEMP_HOT" "$TEMP_CRITICAL" "$BOOST_TEMP_LIMIT" \
        "$LOAD_HIGH%" "$(format_seconds "$LOAD_HIGH_DURATION")" \
        "$LOAD_IDLE%" "$(format_seconds "$LOAD_IDLE_DURATION")" \
        "$(format_seconds "$PROMPT_COOLDOWN")" "$(mode_description "$mode")"
    AUTO_MODE="$old_mode"
    refresh_mode_settings
}

show_modes() {
    echo "Auto mode presets"
    echo ""
    for mode in dynamic gaming creator quiet off; do
        print_mode_row "$mode"
    done
}

refresh_mode_settings

need_root() {
    if [[ $EUID -ne 0 ]]; then
        exec sudo "$0" "$@"
    fi
}

set_config_value() {
    local key="$1" value="$2"
    ensure_state_dir
    touch "$CONF_FILE"
    if grep -qE "^[[:space:]]*${key}=" "$CONF_FILE"; then
        sed -i -E "s|^[[:space:]]*${key}=.*|${key}=${value}|" "$CONF_FILE"
    else
        printf '%s=%s\n' "$key" "$value" >> "$CONF_FILE"
    fi
}

parse_duration() {
    local value="${1:-120}"
    case "$value" in
        *h) echo $(( ${value%h} * 3600 )) ;;
        *m) echo $(( ${value%m} * 60 )) ;;
        *s) echo "${value%s}" ;;
        *) echo "$value" ;;
    esac
}

friendly_profile() {
    case "${1:-unknown}" in
        performance) echo "Performance" ;;
        power-saver) echo "Eco Mode" ;;
        balanced) echo "Balanced" ;;
        *) echo "${1:-unknown}" ;;
    esac
}

format_seconds() {
    local seconds="${1:-0}"
    if (( seconds >= 3600 )); then
        echo "$(( seconds / 3600 ))h $(( seconds % 3600 / 60 ))m"
    elif (( seconds >= 60 )); then
        echo "$(( seconds / 60 ))m"
    else
        echo "${seconds}s"
    fi
}

show_help() {
    cat <<'EOF'
Usage: auto [web|start|stop|restart|status|stats|report|dashboard|doctor|setup|logs|config|modes|mode|quiet-hours|summer-nights|snooze|today-off|resume]

Simple controls:
  auto web              start and open the local web dashboard
  auto dashboard        same as auto web
  auto open             same as auto web
  auto close-web        stop the local web dashboard
  auto setup            guided setup, easiest way to choose behavior
  auto doctor           check if everything needed is installed and healthy
  auto modes            show thresholds for every Auto mode
  auto on               enable dynamic auto mode
  auto off              disable auto mode
  auto mode dynamic     balanced suggestions, adapts to everyday workloads
  auto mode gaming      optimized limits for gaming sessions
  auto mode creator     rendering limits, prioritizes performance
  auto mode quiet       strict thermal/noise limits, best for meetings/library
  auto mode off         turn auto mode off completely

Quiet controls:
  auto quiet-hours 22:00 08:00
  auto quiet-hours off
  auto summer-nights on
  auto summer-nights off
  auto snooze 2h
  auto today-off
  auto resume
  auto stats
  auto report
  auto dashboard

Advanced users can still edit /etc/boost-auto.conf.
EOF
}

show_config_friendly() {
    local ambient=""
    ambient=$(read_ambient_temp_c 2>/dev/null || true)
    cat <<EOF
Auto power helper

Mode: ${AUTO_MODE}
Quiet hours: ${QUIET_HOURS_START}-${QUIET_HOURS_END}
Critical protection: ${ALLOW_CRITICAL_AUTO}
Summer silent nights: ${SUMMER_SILENT_NIGHTS}
Ambient source: ${ambient:-not detected}

What the modes mean:
  dynamic   balanced everyday defaults
  creator   gaming/rendering limits, prioritizes performance
  quiet     strict thermal limits, stays quiet
  off       auto mode is disabled until you run auto start or auto mode ...

Advanced values in ${CONF_FILE}:
  Warm computer: ${TEMP_HOT}
  Too hot: ${TEMP_CRITICAL}
  Boost allowed below: ${BOOST_TEMP_LIMIT}
  Busy: ${LOAD_HIGH} after $(format_seconds "$LOAD_HIGH_DURATION")
  Idle: ${LOAD_IDLE} after $(format_seconds "$LOAD_IDLE_DURATION")
  Minimum time between suggestions: $(format_seconds "$PROMPT_COOLDOWN")

All mode presets:
$(for mode in dynamic gaming creator quiet off; do print_mode_row "$mode"; done)
EOF
}

minutes_from_hhmm() {
    local value="${1:-00:00}"
    local hour="${value%%:*}" minute="${value##*:}"
    echo $(( 10#$hour * 60 + 10#$minute ))
}

in_quiet_hours() {
    [[ "${QUIET_HOURS_START}" == "${QUIET_HOURS_END}" ]] && return 1
    local now_m start_m end_m
    now_m=$(( 10#$(date +%H) * 60 + 10#$(date +%M) ))
    start_m=$(minutes_from_hhmm "$QUIET_HOURS_START")
    end_m=$(minutes_from_hhmm "$QUIET_HOURS_END")
    if (( start_m < end_m )); then
        (( now_m >= start_m && now_m < end_m ))
    else
        (( now_m >= start_m || now_m < end_m ))
    fi
}

pause_status() {
    local until_epoch now_epoch
    if [[ "${AUTO_MODE}" == "off" ]]; then
        echo "Auto mode is off."
        return 0
    fi
    if [[ "${AUTO_MODE}" == "quiet" ]]; then
        echo "Suggestions are disabled in quiet mode; critical heat protection remains active."
        return 0
    fi
    if in_quiet_hours; then
        echo "Suggestions are paused during quiet hours."
        return 0
    fi
    if [[ -f "$SKIP_TODAY_FILE" ]] && [[ "$(cat "$SKIP_TODAY_FILE" 2>/dev/null)" == "$(date +%F)" ]]; then
        echo "Suggestions are paused for today."
        return 0
    fi
    if [[ -f "$SNOOZE_FILE" ]]; then
        until_epoch=$(cat "$SNOOZE_FILE" 2>/dev/null || echo 0)
        now_epoch=$(date +%s)
        if (( until_epoch > now_epoch )); then
            echo "Suggestions are snoozed for $(format_seconds "$(( until_epoch - now_epoch ))")."
            return 0
        fi
    fi
    echo "Suggestions are available."
}

decision_reason() {
    local temp="$1" load="$2" profile="$3"
    if [[ "${AUTO_MODE}" == "off" ]]; then
        echo "Auto mode is off; no automatic suggestions."
    elif [[ "${AUTO_MODE}" == "quiet" ]]; then
        echo "Quiet mode only protects against critical heat."
    elif in_quiet_hours; then
        echo "Quiet hours are active, so suggestions are paused."
    elif [[ -f "$SKIP_TODAY_FILE" ]] && [[ "$(cat "$SKIP_TODAY_FILE" 2>/dev/null)" == "$(date +%F)" ]]; then
        echo "Suggestions are paused for today."
    elif [[ -f "$SNOOZE_FILE" ]] && (( $(cat "$SNOOZE_FILE" 2>/dev/null || echo 0) > $(date +%s) )); then
        echo "Suggestions are snoozed."
    elif (( temp >= BOOST_TEMP_LIMIT )) && [[ "$profile" != "performance" ]]; then
        echo "Not suggesting Boost because CPU is ${temp} C and the ${AUTO_MODE} Boost limit is ${BOOST_TEMP_LIMIT} C."
    elif (( temp >= TEMP_HOT )) && [[ "$profile" == "performance" ]]; then
        echo "A cooler profile is preferred because CPU is ${temp} C and the warm threshold is ${TEMP_HOT} C."
    elif (( load >= LOAD_HIGH )) && [[ "$profile" != "performance" ]]; then
        echo "Boost can be suggested after sustained load if CPU stays below ${BOOST_TEMP_LIMIT} C."
    elif (( load <= LOAD_IDLE )) && [[ "$profile" == "performance" ]]; then
        echo "Powersave can be suggested after sustained idle."
    else
        echo "Current profile looks reasonable for the active mode."
    fi
}

check_item() {
    local ok="$1" label="$2" hint="${3:-}"
    if [[ "$ok" == "yes" ]]; then
        printf 'OK   %s\n' "$label"
    else
        printf 'WARN %s\n' "$label"
        [[ -n "$hint" ]] && printf '     %s\n' "$hint"
    fi
}

show_doctor() {
    local service_state profile notify_actions temp_ok rapl_ok gpu_ok ppd_ok report_ok stats_ok
    service_state=$(systemctl is-active "$SERVICE" 2>/dev/null || echo inactive)
    profile=$(powerprofilesctl get 2>/dev/null || echo unknown)
    command -v powerprofilesctl >/dev/null 2>&1 && ppd_ok=yes || ppd_ok=no
    command -v nvidia-smi >/dev/null 2>&1 && nvidia-smi -L >/dev/null 2>&1 && gpu_ok=yes || gpu_ok=no
    [[ -r /sys/class/powercap/intel-rapl/intel-rapl:0/constraint_0_power_limit_uw ]] && rapl_ok=yes || rapl_ok=no
    if declare -F get_cpu_temp_c >/dev/null && [[ "$(get_cpu_temp_c 2>/dev/null || echo 0)" -gt 0 ]]; then
        temp_ok=yes
    else
        temp_ok=no
    fi
    notify-send --help 2>/dev/null | grep -q -- '--action' && notify_actions=yes || notify_actions=no
    [[ -e /var/lib/power-profile/reports/latest.html ]] && report_ok=yes || report_ok=no
    [[ -s /var/lib/power-profile/stats.csv ]] && stats_ok=yes || stats_ok=no

    cat <<EOF
Auto doctor

Mode:        ${AUTO_MODE}
Service:     ${service_state}
Profile:     $(friendly_profile "$profile")
Quiet hours: ${QUIET_HOURS_START}-${QUIET_HOURS_END}

EOF
    check_item "$ppd_ok" "GNOME power profile sync" "Install power-profiles-daemon for GNOME indicator sync."
    check_item "$gpu_ok" "NVIDIA stats and power limit" "nvidia-smi is missing or cannot see the GPU."
    check_item "$rapl_ok" "CPU power limits" "RAPL path missing; CPU PL1/PL2 tuning may not work on this machine."
    check_item "$temp_ok" "CPU temperature sensor" "Install/configure lm-sensors if temperature is missing."
    check_item "$notify_actions" "Notification buttons" "Your notify-send may not support action buttons."
    check_item "$stats_ok" "Statistics history" "Run 'auto stats' once, or keep auto mode running for a minute."
    check_item "$report_ok" "Latest web report" "Run 'auto report' to generate it."

    cat <<'EOF'

Helpful commands:
  auto setup     choose behavior with a guided menu
  auto stats     see current stats
  auto report    open the web report
EOF
}

run_setup() {
    need_root "$@"
    local choice mode quiet_choice start end

    cat <<'EOF'
Auto setup

Choose how Auto should behave:
  1) Dynamic   - balanced suggestions, adapts to everyday workloads
  2) Gaming    - optimized for gaming sessions, quick to boost
  3) Creator   - rendering/AI limits, prioritizes sustained performance
  4) Quiet     - strict thermal/noise limits, best for meetings/library
  5) Off       - disable auto mode completely
EOF
    printf 'Choice [1]: '
    read -r choice
    case "${choice:-1}" in
        1) mode=dynamic ;;
        2) mode=gaming ;;
        3) mode=creator ;;
        4) mode=quiet ;;
        5) mode=off ;;
        *) echo "Unknown choice, using dynamic."; mode=dynamic ;;
    esac

    set_config_value AUTO_MODE "$mode"

    printf 'Use quiet hours 22:00-08:00? [Y/n]: '
    read -r quiet_choice
    if [[ ! "${quiet_choice:-Y}" =~ ^[Nn]$ ]]; then
        printf 'Quiet starts [22:00]: '
        read -r start
        printf 'Quiet ends [08:00]: '
        read -r end
        set_config_value QUIET_HOURS_START "${start:-22:00}"
        set_config_value QUIET_HOURS_END "${end:-08:00}"
    else
        set_config_value QUIET_HOURS_START 00:00
        set_config_value QUIET_HOURS_END 00:00
    fi

    if [[ "$mode" == "off" ]]; then
        systemctl stop "$SERVICE" 2>/dev/null || true
            echo "Auto mode is off. Run 'auto setup' or 'auto mode dynamic' to enable it again."
    else
        systemctl enable --now "$SERVICE" 2>/dev/null || true
        systemctl restart "$SERVICE" 2>/dev/null || true
        echo "Auto mode is set to '$mode'."
    fi
    echo ""
    "$0" status
}

open_as_user() {
    local url="$1"
    if [[ "$EUID" -ne 0 ]]; then
        xdg-open "$url" >/dev/null 2>&1 || true
        return 0
    fi
    
    local user="${SUDO_USER:-$(logname 2>/dev/null || true)}"
    if [[ -n "$user" && "$user" != "root" ]]; then
        sudo -u "$user" env "XDG_RUNTIME_DIR=/run/user/$(id -u "$user")" "DISPLAY=${DISPLAY:-:0}" "WAYLAND_DISPLAY=${WAYLAND_DISPLAY:-wayland-0}" "DBUS_SESSION_BUS_ADDRESS=unix:path=/run/user/$(id -u "$user")/bus" xdg-open "$url" >/dev/null 2>&1 || true
    else
        xdg-open "$url" >/dev/null 2>&1 || true
    fi
}

start_web() {
    if systemctl is-active --quiet "$WEB_SERVICE" 2>/dev/null; then
        echo "Boost web dashboard is already running: ${WEB_URL}"
        open_as_user "$WEB_URL"
    else
        need_root "$@"
        systemctl enable --now "$WEB_SERVICE" 2>/dev/null || true
        echo "Boost web dashboard started: ${WEB_URL}"
        open_as_user "$WEB_URL"
    fi
}

case "${1:-start}" in
    --daemon)
        exec python3 /usr/local/lib/boost-daemon.py
        ;;
    web|open|dashboard|dashboard-ui)
        start_web "$@"
        exit 0
        ;;
    close-web|web-stop)
        need_root "$@"
        systemctl stop "$WEB_SERVICE" 2>/dev/null || true
        echo "Boost web dashboard stopped."
        exit 0
        ;;
    on)
        "$0" mode dynamic
        exit 0
        ;;
    off|dynamic|gaming|creator|quiet)
        "$0" mode "$1"
        exit 0
        ;;
    start)
        need_root "$@"
        if [[ "${AUTO_MODE}" == "off" ]]; then
            set_config_value AUTO_MODE dynamic
            AUTO_MODE=dynamic
            apply_mode_preset
        fi
        sudo systemctl enable --now "$SERVICE" 2>/dev/null && \
            echo "Auto power helper is running. Use 'auto status' to check it." || \
            echo "Could not start $SERVICE. Is the service installed?" >&2
        exit $?
        ;;
    stop)
        sudo systemctl stop "$SERVICE" && echo "Auto power helper stopped."
        exit $?
        ;;
    restart)
        sudo systemctl restart "$SERVICE" && echo "Auto power helper restarted."
        exit $?
        ;;
    status)
        service_state=$(systemctl is-active "$SERVICE" 2>/dev/null || true)
        [[ -z "$service_state" || "$service_state" == "inactive" ]] && service_state="inactive"
        web_state=$(systemctl is-active "$WEB_SERVICE" 2>/dev/null || true)
        [[ -z "$web_state" || "$web_state" == "inactive" ]] && web_state="inactive"

        profile=$(powerprofilesctl get 2>/dev/null || echo unknown)
        ambient=$(read_ambient_temp_c 2>/dev/null || true)
        echo "Auto helper: $service_state"
        echo "Web dashboard: $web_state (${WEB_URL})"
        echo "Current mode: ${AUTO_MODE}"
        echo "Power profile: $(friendly_profile "$profile")"
        local_coretemp=$(find /sys/class/hwmon -name 'name' -exec grep -l coretemp {} \; 2>/dev/null | head -1 | xargs dirname 2>/dev/null)
        if [[ -n "$local_coretemp" ]]; then
            temp=$(cat "${local_coretemp}/temp1_input" 2>/dev/null || echo 0)
            echo "Computer warmth: $(( temp / 1000 ))"
        fi
        echo "Ambient temperature: ${ambient:-not detected}"
        echo "Suggestions: $(pause_status)"
        echo "Decision: $(decision_reason "$(( ${temp:-0} / 1000 ))" 0 "$profile")"
        echo "Quiet hours: ${QUIET_HOURS_START}-${QUIET_HOURS_END}"
        echo "Summer silent nights: ${SUMMER_SILENT_NIGHTS}"
        echo "Config: $CONF_FILE"
        exit 0
        ;;
    logs)
        journalctl -u "$SERVICE" -f --no-pager
        exit 0
        ;;
    stats)
        "$REPORT_BIN" --text
        exit 0
        ;;
    report)
        "$REPORT_BIN" --open
        exit 0
        ;;
    doctor|health)
        show_doctor
        exit 0
        ;;
    setup|wizard)
        run_setup "$@"
        exit 0
        ;;
    config)
        show_config_friendly
        exit 0
        ;;
    modes|presets)
        show_modes
        exit 0
        ;;
    mode)
        [[ $# -eq 1 ]] && { echo "Current mode: ${AUTO_MODE}"; echo "Available: dynamic, creator, quiet, off, custom"; exit 0; }
        case "$2" in dynamic|gaming|creator|quiet|off) ;; *) echo "Use: dynamic, gaming, creator, quiet, off" >&2; exit 1 ;; esac
        need_root "$@"
        set_config_value AUTO_MODE "$2"
        if [[ "$2" == "off" ]]; then
            systemctl stop "$SERVICE" 2>/dev/null || true
        else
            systemctl enable --now "$SERVICE" 2>/dev/null || true
            systemctl restart "$SERVICE" 2>/dev/null || true
        fi
        echo "Auto mode set to '$2'."
        exit 0
        ;;
    quiet-hours)
        if [[ "${2:-}" == "off" ]]; then
            need_root "$@"
            set_config_value QUIET_HOURS_START 00:00
            set_config_value QUIET_HOURS_END 00:00
            systemctl restart "$SERVICE" 2>/dev/null || true
            echo "Quiet hours disabled."
            exit 0
        fi
        [[ $# -eq 3 ]] || { echo "Usage: auto quiet-hours 22:00 08:00 | off" >&2; exit 1; }
        need_root "$@"
        set_config_value QUIET_HOURS_START "$2"
        set_config_value QUIET_HOURS_END "$3"
        systemctl restart "$SERVICE" 2>/dev/null || true
        echo "Quiet hours set to $2-$3."
        exit 0
        ;;
    summer-nights)
        case "${2:-}" in
            on|yes|true|1)
                need_root "$@"
                set_config_value SUMMER_SILENT_NIGHTS yes
                systemctl restart "$SERVICE" 2>/dev/null || true
                echo "Summer silent nights enabled. Quiet hours will enforce Eco Mode."
                ;;
            off|no|false|0)
                need_root "$@"
                set_config_value SUMMER_SILENT_NIGHTS no
                systemctl restart "$SERVICE" 2>/dev/null || true
                echo "Summer silent nights disabled."
                ;;
            *)
                echo "Usage: auto summer-nights on|off" >&2
                exit 1
                ;;
        esac
        exit 0
        ;;
    snooze)
        need_root "$@"
        ensure_state_dir
        seconds=$(parse_duration "${2:-2h}")
        echo "$(( $(date +%s) + seconds ))" > "$SNOOZE_FILE"
        echo "Auto suggestions snoozed for $(format_seconds "$seconds")."
        exit 0
        ;;
    today-off)
        need_root "$@"
        ensure_state_dir
        date +%F > "$SKIP_TODAY_FILE"
        echo "Auto suggestions paused for today."
        exit 0
        ;;
    resume)
        need_root "$@"
        rm -f "$SNOOZE_FILE" "$SKIP_TODAY_FILE"
        echo "Auto suggestions resumed."
        exit 0
        ;;
    --help|-h|help)
        show_help
        exit 0
        ;;
    *)
        echo "Unknown command: $1" >&2
        show_help >&2
        exit 1
        ;;
esac

ensure_state_dir

