#!/usr/bin/env bash
# restore - revert to boot-time state
# Version: 1.2.0

# shellcheck source=/usr/local/lib/power-common.sh disable=SC1091
source /usr/local/lib/power-common.sh

if [[ "$1" == "--status" ]]; then show_status; exit 0; fi
if [[ "$1" == "--version" ]]; then echo "restore $VERSION"; exit 0; fi

check_root "$@"

ORIG_USER="${SUDO_USER:-$(logname 2>/dev/null)}"

if [[ ! -f "$ORIGINALS_FILE" ]]; then
    echo "[RESTORE] No originals at $ORIGINALS_FILE" >&2; exit 1
fi

# shellcheck source=/dev/null
source "$ORIGINALS_FILE"
echo "[RESTORE] Reverting to saved originals..."

# Restore CPU via ppd or manual
if [[ -n "${ORIG_PPD_PROFILE}" ]]; then
    set_cpu_profile "$ORIG_PPD_PROFILE" "${ORIG_GOV:-performance}" "${ORIG_EPP:-performance}"
else
    set_cpu_profile "balanced" "${ORIG_GOV:-performance}" "${ORIG_EPP:-performance}"
fi

safe_write "${ORIG_TURBO:-0}" /sys/devices/system/cpu/intel_pstate/no_turbo
echo "[CPU]  turbo=$([ "${ORIG_TURBO:-0}" = "0" ] && echo ON || echo OFF)"

apply_hardware_limits restore
set_io_schedulers

safe_write "${ORIG_THP:-madvise}" /sys/kernel/mm/transparent_hugepage/enabled
echo "[VM]   THP=${ORIG_THP}"


restore_fan_curve
reset_process_priorities "$ORIG_USER"

logger -t power-profile "restore applied"
echo "[RESTORE] Done."
show_status
