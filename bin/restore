#!/usr/bin/env bash
# restore - revert to pre-profile system state (saved originals + fan curve)

source /usr/local/lib/power-common.sh
check_root "$@"

if [[ "$1" == "--status" ]]; then show_status; exit 0; fi

ORIGINALS_FILE="/var/lib/power-profile/originals.env"
FAN_BACKUP="/var/lib/power-profile/fan-curve-backup.env"
HWMON="/sys/class/hwmon/hwmon5"
ORIG_USER="${SUDO_USER:-$(logname 2>/dev/null)}"

if [[ ! -f "$ORIGINALS_FILE" ]]; then
    echo "[RESTORE] No originals at $ORIGINALS_FILE" >&2; exit 1
fi

source "$ORIGINALS_FILE"
echo "[RESTORE] Reverting to saved originals..."

for gov in /sys/devices/system/cpu/cpu*/cpufreq/scaling_governor; do
    echo "${ORIG_GOV:-performance}" > "$gov"
done
for epp in /sys/devices/system/cpu/cpu*/cpufreq/energy_performance_preference; do
    echo "${ORIG_EPP:-performance}" > "$epp"
done
echo "[CPU]  governor=${ORIG_GOV}, EPP=${ORIG_EPP}"

safe_write "${ORIG_TURBO:-0}" /sys/devices/system/cpu/intel_pstate/no_turbo
echo "[CPU]  turbo=$([ "${ORIG_TURBO}" = "0" ] && echo ON || echo OFF)"

set_rapl 0 "${ORIG_PL1:-125000000}"
set_rapl 1 "${ORIG_PL2:-253000000}"
echo "[CPU]  PL1=$(( ${ORIG_PL1:-125000000} / 1000000 ))W, PL2=$(( ${ORIG_PL2:-253000000} / 1000000 ))W"

set_io_schedulers

safe_write "${ORIG_THP:-madvise}" /sys/kernel/mm/transparent_hugepage/enabled
echo "[VM]   transparent_hugepages=${ORIG_THP}"

if [[ -n "${ORIG_GPU_LIMIT}" ]]; then
    nvidia-smi -pm 1 -i 0 > /dev/null 2>&1
    nvidia-smi --power-limit="${ORIG_GPU_LIMIT}" -i 0 > /dev/null 2>&1
    echo "[GPU]  power-limit=${ORIG_GPU_LIMIT}W"
fi

# Restore fan curve if backup exists
if [[ -f "$FAN_BACKUP" && -d "$HWMON" ]]; then
    source "$FAN_BACKUP"
    for i in 1 2 3 4 5; do
        pwm_var="ORIG_PWM_PT${i}_PWM"
        temp_var="ORIG_PWM_PT${i}_TEMP"
        safe_write "${!pwm_var}" "${HWMON}/pwm1_auto_point${i}_pwm" 2>/dev/null || true
        safe_write "${!temp_var}" "${HWMON}/pwm1_auto_point${i}_temp" 2>/dev/null || true
    done
    safe_write "${ORIG_PWM1_FLOOR:-1}" "${HWMON}/pwm1_floor" 2>/dev/null || true
    echo "[FAN]  Smart Fan IV curve restored"
fi

# Reset process nice values for current user back to 0
if [[ -n "$ORIG_USER" ]]; then
    reniced=0
    while IFS= read -r pid; do
        renice -n 0 -p "$pid" > /dev/null 2>&1 && ((reniced++)) || true
    done < <(ps -u "$ORIG_USER" -o pid= 2>/dev/null)
    echo "[PROC] $reniced processes -> nice 0 (default)"
fi

logger -t power-profile "restore applied"
echo "[RESTORE] Done."
show_status
