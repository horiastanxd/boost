#!/usr/bin/env bash
# silent - overnight mode: minimum power, quiet fans, priority process
# Version: 1.6.0

# shellcheck source=/usr/local/lib/power-common.sh disable=SC1091
source /usr/local/lib/power-common.sh

if [[ "$1" == "--status" ]]; then show_status; exit 0; fi
if [[ "$1" == "--version" ]]; then echo "silent $VERSION"; exit 0; fi

check_root "$@"

AUTO_SILENT=0
if [[ "${1:-}" == "--auto" ]]; then
    AUTO_SILENT=1
    shift
fi

ORIG_USER="${SUDO_USER:-$(logname 2>/dev/null)}"

apply_quiet_fan_curve() {
    [[ ! -d "$HWMON" ]] && echo "[FAN]  hwmon not found, skipping" && return
    save_fan_curve
    local pwm_vals=(30 80 150 220 255)
    local i=1
    for v in "${pwm_vals[@]}"; do
        safe_write "$v" "${HWMON}/pwm1_auto_point${i}_pwm"
        ((i++))
    done
    echo "[FAN]  Smart Fan IV -> 12%/31%/59%/86%/100% (temp thresholds unchanged)"
}

select_and_prioritize() {
    if [[ "$AUTO_SILENT" == "1" ]]; then
        echo "[PROC] auto mode: skipping interactive process priority selection"
        return 0
    fi

    echo ""
    echo "Top processes for '$ORIG_USER':"
    echo "---"
    ps aux --sort=-%cpu | awk -v u="$ORIG_USER" \
        'NR>1 && $1==u {printf "  PID=%-7s CPU=%-5s %s\n", $2, $3, $11}' | head -12
    echo "---"
    echo -n "Process to keep at HIGH priority (Enter to skip): "

    local priority_proc=""
    read -r priority_proc < /dev/tty 2>/dev/null || priority_proc=""

    # Removed dangerous bulk renice of all user processes to +15.
    # By prioritizing the chosen process to -5, it automatically gets CPU priority
    # over standard nice 0 processes, without breaking the desktop environment or causing mouse lag.

    if [[ -n "$priority_proc" ]]; then
        local pids
        if [[ "$priority_proc" =~ ^[0-9]+$ ]]; then
            pids="$priority_proc"
        else
            pids=$(ps -u "$ORIG_USER" -o pid=,comm= | awk -v p="$priority_proc" '$2~p{print $1}' | tr '\n' ' ')
        fi
        if [[ -n "$pids" ]]; then
            for pid in $pids; do
                renice -n -5 -p "$pid" > /dev/null 2>&1 || true
                ionice -c 2 -n 0 -p "$pid" > /dev/null 2>&1 || true
            done
            echo "[PROC] '$priority_proc' (PIDs: $pids) -> nice -5, ionice high"
        else
            echo "[PROC] No match for '$priority_proc'"
        fi
    fi
}

echo "[SILENT] Applying overnight profile..."
save_originals

# power-saver -> ppd sets governor=powersave, EPP=power
set_cpu_profile "power-saver" "powersave" "power"

set_turbo off
apply_hardware_limits silent
set_io_schedulers
apply_peripheral_power silent

safe_write never /sys/kernel/mm/transparent_hugepage/enabled
echo "[VM]   THP=never"

apply_quiet_fan_curve
select_and_prioritize

logger -t power-profile "silent applied by $ORIG_USER"
echo ""
echo "[SILENT] Done. Run 'boost' or 'powersave' in the morning."
show_status
