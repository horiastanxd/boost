#!/usr/bin/env bash
# power-report - text and HTML reports for boost power statistics
# Version: 1.3.0

set -euo pipefail

# shellcheck source=/dev/null
source /usr/local/lib/power-common.sh

REPORT_DIR="/var/lib/power-profile/reports"
REPORT_FILE=""
OPEN_REPORT=0
TEXT_ONLY=0
HISTORY_ROWS=120

usage() {
    cat <<'EOF'
Usage: power-report [--text] [--open] [--output FILE] [--history ROWS]

Examples:
  power-report --text
  power-report --open
  power-report --output /tmp/boost-report.html
EOF
}

if [[ $EUID -ne 0 ]]; then
    exec sudo "$0" "$@"
fi

while [[ $# -gt 0 ]]; do
    case "$1" in
        --text)
            TEXT_ONLY=1
            shift
            ;;
        --open)
            OPEN_REPORT=1
            shift
            ;;
        --output)
            REPORT_FILE="${2:-}"
            [[ -n "$REPORT_FILE" ]] || { echo "--output needs a file" >&2; exit 1; }
            shift 2
            ;;
        --history)
            HISTORY_ROWS="${2:-120}"
            [[ "$HISTORY_ROWS" =~ ^[0-9]+$ ]] || { echo "--history needs a number" >&2; exit 1; }
            shift 2
            ;;
        --help|-h)
            usage
            exit 0
            ;;
        *)
            echo "Unknown option: $1" >&2
            usage >&2
            exit 1
            ;;
    esac
done

html_escape() {
    sed -e 's/&/\&amp;/g' -e 's/</\&lt;/g' -e 's/>/\&gt;/g' -e 's/"/\&quot;/g'
}

record_power_sample

latest_line=$(tail -n 1 "$STATS_FILE")
IFS=',' read -r _epoch iso profile cpu_load cpu_temp gpu_temp gpu_power gpu_limit pl1 pl2 governor epp turbo battery_pct battery_status <<< "$latest_line"

if [[ "$TEXT_ONLY" == "1" ]]; then
    cat <<EOF
Power report

Time:      ${iso}
Profile:   ${profile}
CPU:       ${cpu_load}% load, ${cpu_temp} C
GPU:       ${gpu_temp} C, ${gpu_power} W / ${gpu_limit} W
Limits:    PL1 ${pl1} W, PL2 ${pl2} W
Governor:  ${governor}
EPP:       ${epp}
Turbo:     ${turbo}
Battery:   ${battery_pct:-N/A}% (${battery_status:-Unknown})
History:   ${STATS_FILE}
EOF
    exit 0
fi

mkdir -p "$REPORT_DIR"
if [[ -z "$REPORT_FILE" ]]; then
    REPORT_FILE="${REPORT_DIR}/report-$(date +%Y%m%d-%H%M%S).html"
fi

history_tmp=$(mktemp)
trap 'rm -f "$history_tmp"' EXIT
tail -n "$HISTORY_ROWS" "$STATS_FILE" > "$history_tmp"

summary=$(awk -F, '$1 ~ /^[0-9]+$/ {
    count++
    cpu += $4
    temp += $5
    gpu += $7
    if ($5 > max_temp) max_temp = $5
    if ($4 > max_cpu) max_cpu = $4
}
END {
    if (count == 0) count = 1
    printf "%.0f,%.0f,%.1f,%.0f,%.0f", cpu / count, temp / count, gpu / count, max_temp, max_cpu
}' "$history_tmp")
IFS=',' read -r avg_cpu avg_temp avg_gpu max_temp max_cpu <<< "$summary"

{
cat <<EOF
<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Boost Power Report</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Outfit:wght@400;600;700;800&display=swap');
:root{color-scheme:dark;--bg-gradient:radial-gradient(circle at 10% 20%, rgba(12,20,39,1) 0%, rgba(5,9,18,1) 90%);--panel-bg:rgba(13,24,45,0.6);--panel-border:rgba(255,255,255,0.07);--text-main:#f1f5f9;--text-muted:#94a3b8;--accent:#0ea5e9;--accent-glow:rgba(14,165,233,0.35);--color-boost:#f43f5e;--color-powersave:#10b981;--font-title:'Outfit',-apple-system,BlinkMacSystemFont,sans-serif;--font-body:'Inter',-apple-system,BlinkMacSystemFont,sans-serif}
body{margin:0;background:var(--bg-gradient);background-attachment:fixed;color:var(--text-main);font-family:var(--font-body);line-height:1.5;-webkit-font-smoothing:antialiased}
main{max-width:1120px;margin:0 auto;padding:40px 24px}
h1{font-family:var(--font-title);font-weight:800;font-size:32px;margin:0 0 4px;background:linear-gradient(to right,#38bdf8,#818cf8,#f43f5e);-webkit-background-clip:text;-webkit-text-fill-color:transparent;letter-spacing:-0.02em}
.muted{color:var(--text-muted);font-size:14px}
.grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:16px;margin:24px 0}
.card{background:var(--panel-bg);border:1px solid var(--panel-border);backdrop-filter:blur(16px);-webkit-backdrop-filter:blur(16px);border-radius:14px;padding:18px;box-shadow:0 8px 24px rgba(0,0,0,0.2)}
.label{color:var(--text-muted);font-size:11px;text-transform:uppercase;letter-spacing:.05em;font-weight:600}
.value{font-size:22px;font-weight:750;margin-top:6px}
.value small{font-size:13px;color:var(--text-muted);font-weight:500}
.pill{display:inline-block;padding:2px 10px;border-radius:999px;background:rgba(14,165,233,0.15);color:var(--accent);border:1px solid rgba(14,165,233,0.2);font-weight:500;font-size:13px}
.chart-container{background:rgba(13,24,45,0.4);border:1px solid rgba(255,255,255,0.05);border-radius:12px;padding:16px;margin:20px 0}
.chart-svg{width:100%;height:180px;display:block}
.chart-legend{display:flex;gap:16px;justify-content:center;margin-top:8px;font-size:12px}
.legend-item{display:flex;align-items:center;gap:6px}
.legend-dot{width:10px;height:10px;border-radius:2px}
.table-wrap{overflow-x:auto;border-radius:12px;border:1px solid rgba(255,255,255,0.05);margin-top:16px}
table{width:100%;border-collapse:collapse;background:rgba(15,23,42,0.3)}
th,td{text-align:left;padding:12px 16px;border-bottom:1px solid rgba(255,255,255,0.05);white-space:nowrap}
th{color:var(--text-muted);font-size:11px;text-transform:uppercase;letter-spacing:0.06em;background:rgba(255,255,255,0.02)}
tr:last-child td{border-bottom:0}tr:hover td{background:rgba(255,255,255,0.01)}
</style>
</head>
<body>
<main>
<h1>Boost Power Report</h1>
<div class="muted">Generated at $(date -Is). Source: $(printf '%s' "$STATS_FILE" | html_escape)</div>
<section class="grid">
<div class="card"><div class="label">Current profile</div><div class="value"><span class="pill">$(printf '%s' "$profile" | html_escape)</span></div></div>
<div class="card"><div class="label">CPU now</div><div class="value">${cpu_load}% <small>${cpu_temp} C</small></div></div>
<div class="card"><div class="label">GPU now</div><div class="value">${gpu_power} W <small>${gpu_temp} C</small></div></div>
<div class="card"><div class="label">Power limits</div><div class="value">${pl1}/${pl2} W</div></div>
<div class="card"><div class="label">Average CPU</div><div class="value">${avg_cpu}% <small>max ${max_cpu}%</small></div></div>
<div class="card"><div class="label">Average temp</div><div class="value">${avg_temp} C <small>max ${max_temp} C</small></div></div>
<div class="card"><div class="label">Average GPU power</div><div class="value">${avg_gpu} W</div></div>
<div class="card"><div class="label">Turbo</div><div class="value">${turbo}</div></div>
<div class="card"><div class="label">Battery</div><div class="value">${battery_pct:-N/A}% <small>${battery_status:-Unknown}</small></div></div>
</section>

<div class="card" style="padding: 20px; margin-bottom: 24px;">
  <div class="label" style="margin-bottom: 12px;">Power & Thermal History</div>
  <svg id="historyChart" class="chart-svg" viewBox="0 0 1000 180" preserveAspectRatio="none">
    <text x="50%" y="50%" text-anchor="middle" fill="#94a3b8">Drawing chart...</text>
  </svg>
  <div class="chart-legend">
    <div class="legend-item"><span class="legend-dot" style="background:#0ea5e9;"></span><span>CPU Load (%)</span></div>
    <div class="legend-item"><span class="legend-dot" style="background:#f59e0b;"></span><span>CPU Temp (°C)</span></div>
    <div class="legend-item"><span class="legend-dot" style="background:#ec4899;"></span><span>GPU Power (W / 200)</span></div>
  </div>
</div>

<h2>Recent Samples</h2>
<div class="table-wrap">
<table>
<thead><tr><th>Time</th><th>Profile</th><th>CPU</th><th>CPU temp</th><th>GPU</th><th>Limits</th><th>Governor</th><th>EPP</th><th>Battery</th><th>Turbo</th></tr></thead>
<tbody>
EOF

tail -n "$HISTORY_ROWS" "$STATS_FILE" | awk -F, '$1 ~ /^[0-9]+$/ {
    printf "<tr><td>%s</td><td>%s</td><td>%s%%</td><td>%s C</td><td>%s C / %s W</td><td>%s/%s W</td><td>%s</td><td>%s</td><td>%s%%</td><td>%s</td></tr>\n", $2, $3, $4, $5, $6, $7, $9, $10, $11, $12, $14, $13
}'

cat <<'EOF'
</tbody>
</table>
</div>
</main>

<script>
const history = [
EOF

tail -n "$HISTORY_ROWS" "$STATS_FILE" | awk -F, '$1 ~ /^[0-9]+$/ {
    printf "{iso:\"%s\",profile:\"%s\",cpu_load:%d,cpu_temp:%d,gpu_temp:%d,gpu_power:%d,pl1:%d,pl2:%d,battery_pct:\"%s\"},\n", $2, $3, $4, $5, $6, $7, $9, $10, $14
}'

cat <<'EOF'
];

function drawHistoryChart(history) {
  const svg = document.getElementById('historyChart');
  if (!history || history.length === 0) {
    svg.innerHTML = '<text x="50%" y="50%" text-anchor="middle" fill="#94a3b8">No history data available</text>';
    return;
  }
  
  const width = 1000;
  const height = 180;
  const paddingLeft = 40;
  const paddingRight = 20;
  const paddingTop = 20;
  const paddingBottom = 25;
  
  const chartWidth = width - paddingLeft - paddingRight;
  const chartHeight = height - paddingTop - paddingBottom;
  
  const pointsCount = history.length;
  let loadPoints = [];
  let tempPoints = [];
  let gpuPoints = [];
  
  for (let i = 0; i < pointsCount; i++) {
    const x = paddingLeft + (i / (pointsCount - 1)) * chartWidth;
    const loadVal = parseFloat(history[i].cpu_load || 0);
    const tempVal = parseFloat(history[i].cpu_temp || 0);
    const gpuVal = parseFloat(history[i].gpu_power || 0);
    const gpuPct = (gpuVal / 200) * 100;
    
    const loadY = height - paddingBottom - (loadVal / 100) * chartHeight;
    const tempY = height - paddingBottom - (tempVal / 100) * chartHeight;
    const gpuY = height - paddingBottom - (Math.min(gpuPct, 100) / 100) * chartHeight;
    
    loadPoints.push(`${x},${loadY}`);
    tempPoints.push(`${x},${tempY}`);
    gpuPoints.push(`${x},${gpuY}`);
  }
  
  let gridLines = '';
  for (let pct = 0; pct <= 100; pct += 25) {
    const y = height - paddingBottom - (pct / 100) * chartHeight;
    gridLines += `<line x1="${paddingLeft}" y1="${y}" x2="${width - paddingRight}" y2="${y}" stroke="rgba(255,255,255,0.06)" stroke-width="1"/>`;
    gridLines += `<text x="${paddingLeft - 10}" y="${y + 4}" fill="#64748b" font-size="10" font-family="sans-serif" text-anchor="end">${pct}%</text>`;
  }
  
  const loadPath = `<path d="M ${loadPoints.join(' L ')}" fill="none" stroke="#0ea5e9" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" />`;
  const tempPath = `<path d="M ${tempPoints.join(' L ')}" fill="none" stroke="#f59e0b" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" />`;
  const gpuPath = `<path d="M ${gpuPoints.join(' L ')}" fill="none" stroke="#ec4899" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" />`;
  
  svg.innerHTML = `
    <g class="grid-lines">${gridLines}</g>
    <g class="chart-paths">
      ${loadPath}
      ${tempPath}
      ${gpuPath}
    </g>
  `;
}

drawHistoryChart(history);
</script>
</body>
</html>
EOF
} > "$REPORT_FILE"

if [[ "$(readlink -f "$REPORT_FILE")" != "$(readlink -f "${REPORT_DIR}/latest.html" 2>/dev/null || true)" ]]; then
    ln -sf "$REPORT_FILE" "${REPORT_DIR}/latest.html"
fi
echo "Report: ${REPORT_FILE}"

if [[ "$OPEN_REPORT" == "1" ]]; then
    open_user="${SUDO_USER:-}"
    if [[ -n "$open_user" ]]; then
        sudo -u "$open_user" xdg-open "$REPORT_FILE" >/dev/null 2>&1 || true
    else
        xdg-open "$REPORT_FILE" >/dev/null 2>&1 || true
    fi
fi
