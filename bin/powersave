#!/usr/bin/env bash
# powersave - efficient profile: balanced performance + lower temps
# Version: 1.1.0

# shellcheck source=/dev/null
source /usr/local/lib/power-common.sh
if [[ "$1" == "--status" ]]; then show_status; exit 0; fi
if [[ "$1" == "--version" ]]; then echo "powersave $VERSION"; exit 0; fi

check_root "$@"

ORIG_USER="${SUDO_USER:-$(logname 2>/dev/null)}"

disable_auto_for_manual_profile "Powersave"

echo "[POWERSAVE] Applying efficient profile..."
save_originals

# balanced -> ppd sets governor=powersave, EPP=balance_performance
set_cpu_profile "balanced" "powersave" "balance_performance"

set_turbo off
apply_hardware_limits powersave
set_io_schedulers

safe_write madvise /sys/kernel/mm/transparent_hugepage/enabled
echo "[VM]   THP=madvise"


restore_fan_curve
reset_process_priorities "$ORIG_USER"

logger -t power-profile "powersave applied"
echo "[POWERSAVE] Done."
show_status
