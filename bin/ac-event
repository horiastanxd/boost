#!/usr/bin/env bash
# ac-event - Handles AC/Battery power events from udev
# Version: 1.6.0

# --boot: called at startup (no graphical session yet; skip notifications, skip sleep)
BOOT_MODE=0
[[ "${1:-}" == "--boot" ]] && BOOT_MODE=1

[[ "$BOOT_MODE" == "0" ]] && sleep 1 # Wait briefly for hardware state to settle

# Source shared helpers for battery detection
# shellcheck source=/dev/null
[[ -f /usr/local/lib/power-common.sh ]] && source /usr/local/lib/power-common.sh

# Source config for AC/Battery profile preferences
AUTO_CONF_FILE="/etc/boost-auto.conf"
AC_PROFILE="restore"
BATTERY_PROFILE="powersave"
BATTERY_LOW_PCT=20
BATTERY_CRITICAL_PCT=10
BATTERY_LOW_NOTIFY=yes
if [[ -f "$AUTO_CONF_FILE" ]]; then
    read_safe_config "$AUTO_CONF_FILE"
fi

ac_online=$(get_ac_online)
[[ -z "$ac_online" ]] && exit 0

STATE_DIR="/run/boost-power"
STATE_FILE="$STATE_DIR/ac-event.state"
LOCK_FILE="$STATE_DIR/ac-event.lock"
mkdir -p "$STATE_DIR" 2>/dev/null || true
exec 9>"$LOCK_FILE"
flock -n 9 || exit 0

should_handle_state() {
    local current_state="$1"
    local last_state

    if [[ -r "$STATE_FILE" ]]; then
        read -r last_state < "$STATE_FILE" 2>/dev/null || true
    fi

    if [[ "$last_state" == "$current_state" ]]; then
        return 1
    fi

    printf '%s\n' "$current_state" > "$STATE_FILE" 2>/dev/null || true
    return 0
}

get_user_env() {
    local session user uid wayland x11
    session=$(loginctl list-sessions --no-legend 2>/dev/null | awk '
        $NF=="active" { print $1; found=1; exit }
        NR==1 { first=$1 }
        END { if (!found && first) print first }')
    [[ -z "$session" ]] && return 1
    user=$(loginctl show-session "$session" -p Name --value 2>/dev/null)
    uid=$(id -u "$user" 2>/dev/null) || return 1
    wayland=""
    for display_socket in "/run/user/$uid"/wayland-*; do
        [[ -e "$display_socket" ]] || continue
        wayland=${display_socket##*/}
        break
    done
    x11=$(loginctl show-session "$session" -p Display --value 2>/dev/null)
    _ENV_USER="$user"
    _ENV_UID="$uid"
    _ENV_WAYLAND="${wayland}"
    _ENV_X11="${x11:-:0}"
    _ENV_DBUS="unix:path=/run/user/$uid/bus"
}

notify_plain() {
    local title="$1" body="$2" urgency="${3:-normal}"
    get_user_env || return
    local _NOTIFY_ENV=(
        "XDG_RUNTIME_DIR=/run/user/$_ENV_UID"
        "DBUS_SESSION_BUS_ADDRESS=$_ENV_DBUS"
    )
    if [[ -n "$_ENV_WAYLAND" ]]; then
        _NOTIFY_ENV+=("WAYLAND_DISPLAY=$_ENV_WAYLAND" "GDK_BACKEND=wayland")
    else
        _NOTIFY_ENV+=("DISPLAY=$_ENV_X11" "GDK_BACKEND=x11")
    fi
    sudo -u "$_ENV_USER" env "${_NOTIFY_ENV[@]}" \
        notify-send -u "$urgency" -a "Boost Power" -i battery "$title" "$body" 2>/dev/null || true
}

# Resolve profile name to command path
profile_cmd() {
    local profile="$1"
    case "$profile" in
        boost)     echo "/usr/local/bin/boost" ;;
        powersave)  echo "/usr/local/bin/powersave" ;;
        silent)    echo "/usr/local/bin/silent" ;;
        restore|*) echo "/usr/local/bin/restore" ;;
    esac
}

# Friendly name for notifications
profile_label() {
    case "$1" in
        boost)     echo "Performance" ;;
        powersave)  echo "Balanced" ;;
        silent)    echo "Power Saver" ;;
        restore)   echo "Default" ;;
        *)         echo "$1" ;;
    esac
}

# Prevent profile scripts from disabling auto mode when triggered by ac-event
export AUTO_HELPER_INTERNAL=1

if [[ "$ac_online" == "1" ]]; then
    should_handle_state "ac" || exit 0
    logger -t boost-ac "AC connected. Applying profile: $AC_PROFILE"
    cmd=$(profile_cmd "$AC_PROFILE")
    $cmd >/dev/null 2>&1 || true
    [[ "$BOOT_MODE" == "0" ]] && notify_plain "AC Power Connected" "Switched to $(profile_label "$AC_PROFILE") profile." "normal"
elif [[ "$ac_online" == "0" ]]; then
    should_handle_state "battery" || exit 0
    logger -t boost-ac "On battery. Applying profile: $BATTERY_PROFILE"
    cmd=$(profile_cmd "$BATTERY_PROFILE")
    $cmd >/dev/null 2>&1 || true

    if [[ "$BOOT_MODE" == "0" ]]; then
        # Check battery level and notify if low
        if [[ "$BATTERY_LOW_NOTIFY" == "yes" ]]; then
            bat_pct=$(get_battery_pct 2>/dev/null || echo "")
            if [[ -n "$bat_pct" && "$bat_pct" -le "$BATTERY_CRITICAL_PCT" ]]; then
                notify_plain "Battery Critical" "Only ${bat_pct}% remaining. System is in maximum power saving mode." "critical"
            elif [[ -n "$bat_pct" && "$bat_pct" -le "$BATTERY_LOW_PCT" ]]; then
                notify_plain "Battery Low" "${bat_pct}% remaining. Switched to $(profile_label "$BATTERY_PROFILE") profile." "normal"
            else
                notify_plain "On Battery" "Switched to $(profile_label "$BATTERY_PROFILE") profile." "normal"
            fi
        else
            notify_plain "On Battery" "Switched to $(profile_label "$BATTERY_PROFILE") profile." "normal"
        fi
    fi
fi
